APP_NAME="User Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8004

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=user_db
DB_USERNAME=app_user
DB_PASSWORD=app_secret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin_secret
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=inventory.events

KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=inventory-management
KEYCLOAK_CLIENT_ID=inventory-api
KEYCLOAK_CLIENT_SECRET=your-client-secret

WEBHOOK_SECRET=your-webhook-secret
